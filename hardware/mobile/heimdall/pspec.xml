<!DOCTYPE PISI SYSTEM "https://pisilinux.org/projeler/pisi/pisi-spec.dtd">
<PISI>
    <Source>
        <Name>heimdall</Name>
        <Homepage>https://git.sr.ht/~grimler/Heimdall</Homepage>
        <Packager>
            <Name>Kamil Atlı</Name>
            <Email>suvari@pisilinux.org</Email>
        </Packager>
        <License>MIT</License>
        <Icon>heimdall</Icon>
        <IsA>library</IsA>
        <Summary>Tool suite used to flash firmware (ROMs) onto Samsung Galaxy S devices (grimler fork)</Summary>
        <Description>Heimdall is a cross-platform open-source tool suite used to flash firmware (aka ROMs) onto Samsung mobile devices.</Description>
        <Archive sha1sum="d397adc7ac0e2e564c7d0bdfc1a266f406ed78bb" type="targz">https://git.sr.ht/~grimler/Heimdall/archive/v2.2.2.tar.gz</Archive>
        <BuildDependencies>
            <Dependency>cmake</Dependency>
            <Dependency>zlib-devel</Dependency>
            <Dependency>libusb-devel</Dependency>
            <Dependency>qt6-base-devel</Dependency>
        </BuildDependencies>
    </Source>

    <Package>
        <Name>heimdall</Name>
        <RuntimeDependencies>
            <Dependency>zlib</Dependency>
            <Dependency>libgcc</Dependency>
            <Dependency>libusb</Dependency>
            <Dependency>qt6-base</Dependency>
        </RuntimeDependencies>
        <Files>
            <Path fileType="executable">/usr/bin</Path>
            <Path fileType="doc">/usr/share/doc</Path>
            <Path fileType="data">/usr/share/applications</Path>
            <Path fileType="config">/usr/lib/udev/rules.d/60-heimdall.rules</Path>
            <Path fileType="data">/usr/share/pixmaps/</Path>
        </Files>
        <AdditionalFiles>
            <AdditionalFile owner="root" permission="0644" target="/usr/share/applications/heimdall.desktop">heimdall.desktop</AdditionalFile>
            <AdditionalFile owner="root" permission="0644" target="/usr/lib/udev/rules.d/60-heimdall.rules">60-heimdall.rules</AdditionalFile>
            <AdditionalFile target="/usr/share/pixmaps/heimdall.png" permission="0644" owner="root">heimdall.png</AdditionalFile>
        </AdditionalFiles>
    </Package>

    <History>
